# ============================================================
# ROOT ENVIRONMENT TEMPLATE (used by docker-compose)
# Copy to .env and adjust. Never commit the real .env file.
# ============================================================

# ---- Global ----
NODE_ENV=development
DEMO_MODE=true                      # true = mock adapters, zero cloud cost

# ---- Ports ----
FRONTEND_PORT=3000
BACKEND_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
MONGO_PORT=27017

# ---- MongoDB ----
# For local container, compose sets this automatically.
# For Atlas, paste your M0 connection string.
MONGO_URI=mongodb://mongo:27017/cloudportability
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- Auth secrets (REQUIRED by the backend; compose fails fast if unset) ----
# Generate strong values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev_only_change_me_access_0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=dev_only_change_me_refresh_fedcba9876543210fedcba9876543210
CORS_ORIGIN=http://localhost:3000
