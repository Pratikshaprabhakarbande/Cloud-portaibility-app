{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Security",
  "uid": "cp-security",
  "tags": ["cloud-portability", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Security score by provider",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "cloud_security_score", "legendFormat": "{{provider}}", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Open incidents",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "cloud_open_incidents", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Auth failures (401/403) req/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status=~\"401|403\"}[5m]))", "legendFormat": "auth failures", "refId": "A" }
      ]
    }
  ]
}
