{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Infrastructure (Runtime)",
  "uid": "cp-infrastructure",
  "tags": ["cloud-portability", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Process CPU (cores)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[5m])", "legendFormat": "cpu", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "rss", "refId": "A" },
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "heap used", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Event loop lag (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "lag", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active handles",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "nodejs_active_handles_total", "refId": "A" }]
    }
  ]
}
