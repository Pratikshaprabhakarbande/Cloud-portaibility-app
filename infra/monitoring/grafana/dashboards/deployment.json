{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Deployments",
  "uid": "cp-deployments",
  "tags": ["cloud-portability", "deployments"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active deployments",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "cloud_active_deployments", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running containers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "cloud_running_containers", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Terraform API calls (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{route=~\".*/terraform.*\"}[5m])) by (route)", "legendFormat": "{{route}}", "refId": "A" }
      ]
    }
  ]
}
