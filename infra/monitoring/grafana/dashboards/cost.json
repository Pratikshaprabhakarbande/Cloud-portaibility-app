{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Cost (FinOps)",
  "uid": "cp-cost",
  "tags": ["cloud-portability", "cost"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total monthly cost (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [{ "expr": "cloud_monthly_cost_usd{provider=\"total\"}", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Monthly cost by provider (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "cloud_monthly_cost_usd{provider!=\"total\"}", "legendFormat": "{{provider}}", "refId": "A" }
      ]
    }
  ]
}
