{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Multi-Cloud Overview",
  "uid": "cp-multi-cloud",
  "tags": ["cloud-portability", "multi-cloud"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Health score by provider",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "cloud_health_score{provider!=\"overall\"}", "legendFormat": "{{provider}}", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Overall health score",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "cloud_health_score{provider=\"overall\"}", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Monthly cost by provider (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [{ "expr": "cloud_monthly_cost_usd{provider!=\"total\"}", "legendFormat": "{{provider}}", "refId": "A" }]
    }
  ]
}
