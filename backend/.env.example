# ============================================================
# BACKEND ENVIRONMENT TEMPLATE
# Copy to backend/.env and adjust. Never commit the real file.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api
# Explicit frontend origin (credentials are enabled; never use "*").
CORS_ORIGIN=http://localhost:3000

# ---- Mode ----
# true  => mock cloud + AI adapters (no credentials, zero cost)
# false => use real cloud/AI credentials below
DEMO_MODE=true

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/cloudportability

# ---- Auth (REQUIRED — the server fails fast if these are missing) ----
# Generate strong values, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev_only_change_me_access_0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=dev_only_change_me_refresh_fedcba9876543210fedcba9876543210
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_MIN=15
BCRYPT_SALT_ROUNDS=10

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Cloud adapter cache ----
CACHE_ENABLED=true
CACHE_TTL_MS=30000
# Optional Redis backend for the cache (falls back to in-memory if unset/unreachable)
REDIS_URL=

# ---- Auth cookie / CSRF (opt-in; default off keeps the Bearer-token flow) ----
AUTH_COOKIE_REFRESH=false
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# ---- Terraform automation engine ----
# false (default) => commands are SIMULATED (no terraform binary, no cloud calls)
# true            => run the real terraform CLI against infra/terraform
TERRAFORM_ENABLED=false
TERRAFORM_BIN=terraform
TERRAFORM_ROOT=../infra/terraform
# Extra guard required for apply/destroy even when terraform is enabled.
TERRAFORM_ALLOW_MUTATIONS=false

# ---- Logging ----
LOG_LEVEL=info

# ---- AWS (optional, only when DEMO_MODE=false) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ---- AI Cloud Advisor ----
# rule (default, zero-cost) | bedrock (opt-in, requires BEDROCK_ENABLED + creds)
AI_PROVIDER=rule
BEDROCK_ENABLED=false

# ---- Azure (optional) ----
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---- GCP (optional) ----
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
