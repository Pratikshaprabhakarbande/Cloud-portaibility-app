# ============================================================
# BACKEND ENVIRONMENT TEMPLATE
# Copy to backend/.env and adjust. Never commit the real file.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000

# ---- Mode ----
# true  => mock cloud + AI adapters (no credentials, zero cost)
# false => use real cloud/AI credentials below
DEMO_MODE=true

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/cloudportability

# ---- Auth ----
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Logging ----
LOG_LEVEL=info

# ---- AWS (optional, only when DEMO_MODE=false) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ---- Azure (optional) ----
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---- GCP (optional) ----
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
