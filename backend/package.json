{
  "name": "cloud-portability-backend",
  "version": "0.2.0",
  "private": true,
  "description": "Backend API for the Multi-Cloud Portability & Deployment Automation Platform",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/seed/seed.js",
    "seed:fresh": "node src/seed/seed.js -- --fresh",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.2",
    "winston": "^3.13.0",
    "nodemailer": "^6.9.14"
  },
  "optionalDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-cloudwatch": "^3.600.0",
    "@aws-sdk/client-cost-explorer": "^3.600.0",
    "@aws-sdk/client-ec2": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@azure/arm-compute": "^24.0.0",
    "@azure/arm-consumption": "^9.0.0",
    "@azure/arm-monitor": "^7.0.0",
    "@azure/arm-network": "^33.0.0",
    "@azure/arm-resources": "^5.2.0",
    "@azure/identity": "^4.2.0",
    "@google-cloud/billing": "^4.3.0",
    "@google-cloud/compute": "^4.5.0",
    "@google-cloud/monitoring": "^4.1.0",
    "@google-cloud/storage": "^7.11.0",
    "dockerode": "^4.0.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.4.1",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0"
  }
